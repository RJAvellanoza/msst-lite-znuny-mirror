# Shared sidebar for Zabbix Event Reports pages
# Include with: [% INCLUDE "AgentEventReportsZabbixSidebar.tt" ActiveSection = "IncidentCreation" %]

<h1>[% Translate("Event Management") | html %]</h1>
<div class="SidebarColumn">
    <div class="WidgetSimple">
        <div class="Header">
            <h2>[% Translate("Navigation") | html %]</h2>
        </div>
        <div class="Content" style="padding: 0;">
            <style>
                .incident-sidebar-nav {
                    list-style: none;
                    margin: 0;
                    padding: 0;
                }
                .incident-sidebar-nav li {
                    margin: 0;
                    border-bottom: 1px solid #e8e8e8;
                }
                .incident-sidebar-nav li:last-child {
                    border-bottom: none;
                }
                .incident-sidebar-nav li a {
                    display: block;
                    padding: 12px 15px;
                    color: #333;
                    text-decoration: none;
                    font-size: 13px;
                    transition: all 0.2s ease;
                    border-left: 3px solid transparent;
                }
                .incident-sidebar-nav li a:hover {
                    background: #f5f5f5;
                    color: #000;
                    border-left-color: #ccc;
                }
                .incident-sidebar-nav li.Active a {
                    background: #e8f4fc;
                    color: #004085;
                    font-weight: bold;
                    border-left-color: #004085;
                }
                .incident-sidebar-nav li a i {
                    margin-right: 8px;
                    width: 16px;
                    text-align: center;
                    color: #666;
                }
                .incident-sidebar-nav li.Active a i {
                    color: #004085;
                }
            </style>
            <ul class="incident-sidebar-nav">
                <li class="[% IF ActiveSection == 'IncidentCreation' || !ActiveSection %]Active[% END %]">
                    <a href="[% Env("Baselink") %]Action=AgentEventReportsZabbix;Section=IncidentCreation">
                        <i class="fa fa-bar-chart"></i>
                        [% Translate("Monitored Events") | html %]
                    </a>
                </li>
                <li class="[% IF ActiveSection == 'TopEntity' %]Active[% END %]">
                    <a href="[% Env("Baselink") %]Action=AgentEventReportsZabbix;Section=TopEntity">
                        <i class="fa fa-sort-amount-desc"></i>
                        [% Translate("Top 10 Impacted CI") | html %]
                    </a>
                </li>
                <!--
                <li class="[% IF ActiveSection == 'TabularData' %]Active[% END %]">
                    <a href="[% Env("Baselink") %]Action=AgentEventManagementDB">
                        <i class="fa fa-table"></i>
                        [% Translate("Tabular Data") | html %]
                    </a>
                </li>
                -->
            </ul>
        </div>
    </div>
</div>
