<div class="MainBox ARIARoleMain LayoutFixedSidebar SidebarFirst">
    <h1 class="InvisibleText">[% Translate("Event Management (Direct)") | html %]</h1>

    <div class="SidebarColumn">
        <div class="WidgetSimple">
            <div class="Header">
                <h2>[% Translate("Filters") | html %]</h2>
            </div>
            <div class="Content">
                <ul class="ActionList">
                    <li>
                        <label for="DaysFilter" style="font-size: 11px; display: block; margin-bottom: 4px;">[% Translate("Days back") | html %]:</label>
                        <select id="DaysFilter" style="width: 100%; margin-bottom: 10px; padding: 4px;">
                            <option value="1">1 day</option>
                            <option value="7">7 days</option>
                            <option value="30">30 days</option>
                            <option value="90">90 days</option>
                            <option value="365">1 year</option>
                            <option value="0" selected>All time</option>
                        </select>
                    </li>
                    <li>
                        <label for="LimitFilter" style="font-size: 11px; display: block; margin-bottom: 4px;">[% Translate("Per page") | html %]:</label>
                        <select id="LimitFilter" style="width: 100%; margin-bottom: 10px; padding: 4px;">
                            <option value="50">50</option>
                            <option value="100" selected>100</option>
                            <option value="250">250</option>
                            <option value="500">500</option>
                        </select>
                    </li>
                    <li>
                        <label for="HostFilter" style="font-size: 11px; display: block; margin-bottom: 4px;">[% Translate("Host filter") | html %]:</label>
                        <input type="text" id="HostFilter" style="width: 100%; margin-bottom: 10px; padding: 4px;" placeholder="hostname">
                    </li>
                    <li>
                        <div id="PaginationControls" style="margin-bottom: 10px;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                                <button type="button" id="PrevPage" class="CallForAction" style="padding: 4px 8px;">
                                    <span><i class="fa fa-chevron-left"></i></span>
                                </button>
                                <span id="PageInfo" style="font-size: 11px;">Page 1</span>
                                <button type="button" id="NextPage" class="CallForAction" style="padding: 4px 8px;">
                                    <span><i class="fa fa-chevron-right"></i></span>
                                </button>
                            </div>
                            <div style="text-align: center; font-size: 10px; color: #666;">
                                <span id="TotalInfo">Total: -</span>
                            </div>
                        </div>
                    </li>
                    <li>
                        <button type="button" id="RefreshData" class="CallForAction Fullsize Center">
                            <span><i class="fa fa-refresh"></i> [% Translate("Refresh") | html %]</span>
                        </button>
                    </li>
                    <li>
                        <button type="button" id="ExportCSV" class="CallForAction Fullsize Center" style="margin-top: 5px;">
                            <span><i class="fa fa-download"></i> [% Translate("Export CSV") | html %]</span>
                        </button>
                    </li>
                </ul>
            </div>
        </div>

        <div class="WidgetSimple">
            <div class="Header">
                <h2>[% Translate("Statistics") | html %]</h2>
            </div>
            <div class="Content">
                <table style="width: 100%; font-size: 12px;">
                    <tr>
                        <td style="padding: 4px 0;"><strong>[% Translate("Total Problems") | html %]:</strong></td>
                        <td style="padding: 4px 0; text-align: right;" id="statTotal">-</td>
                    </tr>
                    <tr style="color: #c62828;">
                        <td style="padding: 4px 0;"><strong>[% Translate("Open") | html %]:</strong></td>
                        <td style="padding: 4px 0; text-align: right;" id="statOpen">-</td>
                    </tr>
                    <tr style="color: #2e7d32;">
                        <td style="padding: 4px 0;"><strong>[% Translate("Resolved") | html %]:</strong></td>
                        <td style="padding: 4px 0; text-align: right;" id="statResolved">-</td>
                    </tr>
                    <tr style="color: #1565c0;">
                        <td style="padding: 4px 0;"><strong>[% Translate("With Ticket") | html %]:</strong></td>
                        <td style="padding: 4px 0; text-align: right;" id="statWithTicket">-</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="WidgetSimple">
            <div class="Header">
                <h2>[% Translate("Info") | html %]</h2>
            </div>
            <div class="Content">
                <p class="FieldExplanation" style="font-size: 11px;">
                    [% Translate("This page shows Zabbix problems directly from the database with full details including item values and SNMP data.") | html %]
                </p>
            </div>
        </div>
    </div>

    <div class="ContentColumn">
        <div class="WidgetSimple">
            <div class="Header">
                <h2>[% Translate("Zabbix Problems (Direct DB)") | html %] <span id="ProblemCount" style="font-weight: normal !important; color: #aaa !important;"></span></h2>
            </div>
            <div class="Content">
                <!-- Entity Filter Banner -->
                <div id="EntityFilterBanner" style="display: none; padding: 10px 15px; background: #d1ecf1; border: 1px solid #bee5eb; color: #0c5460; border-radius: 4px; margin-bottom: 15px;">
                    <i class="fa fa-filter"></i> Filtered by Entity: <strong id="EntityFilterName"></strong>
                    <a href="[% Env("Baselink") %]Action=AgentEventManagementDB" style="margin-left: 15px; color: #0c5460;">[Clear Filter]</a>
                </div>

                <!-- HasTicket Filter Banner -->
                <div id="HasTicketBanner" style="display: none; padding: 10px 15px; background: #d4edda; border: 1px solid #c3e6cb; color: #155724; border-radius: 4px; margin-bottom: 15px;">
                    <i class="fa fa-filter"></i> <span id="HasTicketText"></span>
                    <a href="[% Env("Baselink") %]Action=AgentEventManagementDB" style="margin-left: 15px; color: #155724;">[Clear Filter]</a>
                </div>

                <!-- Error Message -->
                <div id="ErrorMessage" style="display: none; padding: 15px; background: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; border-radius: 4px; margin-bottom: 15px;">
                    <i class="fa fa-exclamation-triangle"></i> <span id="ErrorText"></span>
                </div>

                <!-- Loading Spinner -->
                <div id="LoadingSpinner" style="display: none; text-align: center; padding: 40px;">
                    <i class="fa fa-spinner fa-spin fa-3x"></i>
                    <p style="margin-top: 15px;">[% Translate("Loading problems from database...") | html %]</p>
                </div>

                <!-- Problems Table -->
                <div id="ProblemsTableContainer" style="overflow-x: auto;">
                    <table class="DataTable" id="ProblemsTable" style="width: 100%; font-size: 10px;">
                        <thead>
                            <tr>
                                <!-- LSMP Report Format - 17 columns -->
                                <th style="min-width: 70px;">[% Translate("Alarm ID") | html %]</th>
                                <th style="min-width: 150px;">[% Translate("Event Occur Time") | html %]</th>
                                <th style="min-width: 50px; text-align: center;">[% Translate("Severity") | html %]</th>
                                <th style="min-width: 80px;">[% Translate("Severity Name") | html %]</th>
                                <th style="min-width: 70px;">[% Translate("Trigger ID") | html %]</th>
                                <th style="min-width: 70px;">[% Translate("Event Priority") | html %]</th>
                                <th style="min-width: 70px;">[% Translate("Item ID") | html %]</th>
                                <th style="min-width: 120px;">[% Translate("Event ID") | html %]</th>
                                <th style="min-width: 70px;">[% Translate("Host ID") | html %]</th>
                                <th style="min-width: 120px;">[% Translate("Host Name") | html %]</th>
                                <th style="min-width: 100px;">[% Translate("IP Address") | html %]</th>
                                <th style="min-width: 100px;">[% Translate("Host Groups") | html %]</th>
                                <th style="min-width: 120px;">[% Translate("Incident Number") | html %]</th>
                                <th style="min-width: 100px;">[% Translate("Event ID 2") | html %]</th>
                                <th style="min-width: 150px;">[% Translate("Entity (Impacted CI)") | html %]</th>
                                <th style="min-width: 100px;">[% Translate("Host") | html %]</th>
                                <th style="min-width: 200px;">[% Translate("Message") | html %]</th>
                            </tr>
                        </thead>
                        <tbody id="ProblemsTableBody">
                            <!-- Populated by JavaScript -->
                        </tbody>
                    </table>
                </div>

                <!-- No Problems Message -->
                <div id="NoProblemsMessage" style="display: none; text-align: center; padding: 40px; color: #666;">
                    <i class="fa fa-check-circle fa-3x" style="color: #28a745;"></i>
                    <p style="margin-top: 15px; font-size: 16px;">[% Translate("No problems found") | html %]</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
#ProblemsTable th {
    padding: 6px 4px;
    text-align: left;
    font-weight: bold;
    border-bottom: 2px solid #ddd;
    white-space: nowrap;
    background: #f5f5f5;
    position: sticky;
    top: 0;
}
#ProblemsTable td {
    padding: 4px;
    border-bottom: 1px solid #eee;
    vertical-align: top;
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
#ProblemsTable tr:hover {
    background-color: #f5f5f5;
}
#ProblemsTable tr.open-problem {
    background-color: #fff3e0;
}
.severity-badge {
    display: inline-block;
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 9px;
    font-weight: bold;
    min-width: 18px;
    text-align: center;
}
.truncate {
    max-width: 150px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
</style>

<script type="text/javascript">
(function() {
    'use strict';

    // Initial data from server
    var initialProblems = [% Data.ProblemsJSON %];
    var initialSuccess = [% Data.Success %];
    var initialError = '[% Data.ErrorMessage | html %]';
    var initialTotalCount = [% Data.TotalCount || 0 %];

    // Filter params from URL (passed by backend)
    var entityFilter = '[% Data.EntityFilter | html %]';
    var hasTicketFilter = '[% Data.HasTicket | html %]';
    var startEpochFilter = '[% Data.StartEpoch | html %]';
    var endEpochFilter = '[% Data.EndEpoch | html %]';

    // Pagination state
    var totalCount = initialTotalCount;
    var currentPage = 0;
    var pageSize = 100;
    var daysBack = 0;

    function escapeHtml(text) {
        if (!text) return '';
        var div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function formatTimestamp(ts) {
        if (!ts) return '-';
        // Handle PostgreSQL timestamp format
        if (typeof ts === 'string' && ts.match(/^\d{4}-\d{2}-\d{2}/)) {
            return ts.substring(0, 19).replace('T', ' ');
        }
        return ts;
    }

    function updateStatistics(problems) {
        var total = problems ? problems.length : 0;
        var open = 0;
        var resolved = 0;
        var withTicket = 0;

        if (problems && problems.length > 0) {
            problems.forEach(function(p) {
                if (p.problem_duration === 'OPEN') {
                    open++;
                } else {
                    resolved++;
                }
                if (p.znuny_ticket_nr) {
                    withTicket++;
                }
            });
        }

        document.getElementById('statTotal').textContent = total;
        document.getElementById('statOpen').textContent = open;
        document.getElementById('statResolved').textContent = resolved;
        document.getElementById('statWithTicket').textContent = withTicket;
    }

    function getSeverityBadge(severity) {
        var colors = {
            '5': { bg: '#ffcdd2', text: '#b71c1c', name: 'D' },
            '4': { bg: '#ffe0b2', text: '#e65100', name: 'H' },
            '3': { bg: '#fff9c4', text: '#f57f17', name: 'A' },
            '2': { bg: '#b3e5fc', text: '#01579b', name: 'W' },
            '1': { bg: '#c8e6c9', text: '#1b5e20', name: 'I' },
            '0': { bg: '#eeeeee', text: '#424242', name: 'N' }
        };
        var s = String(severity || '0');
        var c = colors[s] || colors['0'];
        return '<span class="severity-badge" style="background:' + c.bg + ';color:' + c.text + ';" title="' + c.name + '">' + s + '</span>';
    }

    function renderProblems(problems) {
        var tbody = document.getElementById('ProblemsTableBody');
        var tableContainer = document.getElementById('ProblemsTableContainer');
        var noProblemsMsg = document.getElementById('NoProblemsMessage');
        var countSpan = document.getElementById('ProblemCount');

        updateStatistics(problems);

        if (!problems || problems.length === 0) {
            tableContainer.style.display = 'none';
            noProblemsMsg.style.display = 'block';
            countSpan.textContent = '(0)';
            return;
        }

        tableContainer.style.display = 'block';
        noProblemsMsg.style.display = 'none';
        countSpan.textContent = '(' + problems.length + ')';

        var html = '';
        problems.forEach(function(p) {
            var isOpen = (p.problem_duration === 'OPEN');
            var rowClass = isOpen ? 'open-problem' : '';

            html += '<tr class="' + rowClass + '">';
            // LSMP Report Format - 17 columns
            html += '<td>' + escapeHtml(p.problem_eventid) + '</td>';                              // Alarm ID
            html += '<td>' + formatTimestamp(p.problem_start_time) + '</td>';                      // Event Occur Time
            html += '<td style="text-align: center;">' + getSeverityBadge(p.problem_severity) + '</td>'; // Severity
            html += '<td>' + escapeHtml(p.problem_severity_name) + '</td>';                        // Severity Name
            html += '<td>' + escapeHtml(p.trigger_triggerid) + '</td>';                            // Trigger ID
            html += '<td>' + escapeHtml(p.trigger_priority) + '</td>';                             // Event Priority
            html += '<td>' + escapeHtml(p.item_itemid) + '</td>';                                  // Item ID
            html += '<td class="truncate" title="' + escapeHtml(p.item_name) + '">' + escapeHtml(p.item_name) + '</td>'; // Event ID (Item Name)
            html += '<td>' + escapeHtml(p.host_hostid) + '</td>';                                  // Host ID
            html += '<td class="truncate" title="' + escapeHtml(p.host_name) + '">' + escapeHtml(p.host_name) + '</td>'; // Host Name
            html += '<td>' + escapeHtml(p.interface_ip) + '</td>';                                 // IP Address
            html += '<td class="truncate" title="' + escapeHtml(p.host_groups) + '">' + escapeHtml(p.host_groups) + '</td>'; // Host Groups
            html += '<td>' + escapeHtml(p.znuny_ticket_nr) + '</td>';                              // Incident Number
            html += '<td>' + escapeHtml(p.snmp_item_event_id) + '</td>';                           // Event ID 2
            var entity = p.snmp_component || p.host_name || '';
            html += '<td class="truncate" title="' + escapeHtml(entity) + '">' + escapeHtml(entity) + '</td>'; // Entity (Impacted CI)
            html += '<td>' + escapeHtml(p.snmp_device) + '</td>';                                  // Host
            html += '<td class="truncate" title="' + escapeHtml(p.snmp_summary_message) + '">' + escapeHtml(p.snmp_summary_message) + '</td>'; // Message
            html += '</tr>';
        });

        tbody.innerHTML = html;
    }

    function showError(message) {
        var errorDiv = document.getElementById('ErrorMessage');
        var errorText = document.getElementById('ErrorText');
        var tableContainer = document.getElementById('ProblemsTableContainer');
        var noProblemsMsg = document.getElementById('NoProblemsMessage');

        errorText.textContent = message;
        errorDiv.style.display = 'block';
        tableContainer.style.display = 'none';
        noProblemsMsg.style.display = 'none';
    }

    function hideError() {
        document.getElementById('ErrorMessage').style.display = 'none';
    }

    function showLoading() {
        document.getElementById('LoadingSpinner').style.display = 'block';
        document.getElementById('ProblemsTableContainer').style.display = 'none';
        document.getElementById('NoProblemsMessage').style.display = 'none';
        hideError();
    }

    function hideLoading() {
        document.getElementById('LoadingSpinner').style.display = 'none';
    }

    function updatePaginationUI() {
        var totalPages = Math.ceil(totalCount / pageSize) || 1;
        document.getElementById('PageInfo').textContent = 'Page ' + (currentPage + 1) + ' / ' + totalPages;
        document.getElementById('TotalInfo').textContent = 'Total: ' + totalCount + ' problems';

        document.getElementById('PrevPage').disabled = (currentPage <= 0);
        document.getElementById('NextPage').disabled = (currentPage + 1 >= totalPages);
    }

    function loadData() {
        showLoading();

        daysBack = parseInt(document.getElementById('DaysFilter').value) || 1;
        pageSize = parseInt(document.getElementById('LimitFilter').value) || 100;
        var hostFilter = document.getElementById('HostFilter').value || '';
        var offset = currentPage * pageSize;

        var url = Core.Config.Get('Baselink') + 'Action=AgentEventManagementDB;Subaction=GetProblems';
        url += ';Days=' + daysBack;
        url += ';Limit=' + pageSize;
        url += ';Offset=' + offset;
        if (hostFilter) {
            url += ';HostFilter=' + encodeURIComponent(hostFilter);
        }
        if (startEpochFilter && endEpochFilter) {
            url += ';StartEpoch=' + startEpochFilter;
            url += ';EndEpoch=' + endEpochFilter;
        }
        if (hasTicketFilter) {
            url += ';HasTicket=' + hasTicketFilter;
        }

        Core.AJAX.FunctionCall(url, {}, function(response) {
            hideLoading();

            if (response.Success) {
                hideError();
                totalCount = response.TotalCount || 0;
                var filteredProblems = applyEntityFilter(response.Problems);
                renderProblems(filteredProblems);
                updatePaginationUI();
            } else {
                showError(response.ErrorMessage || 'Failed to load problems');
            }
        }, 'json');
    }

    function exportCSV() {
        var problems = initialProblems;
        if (!problems || problems.length === 0) {
            alert('No data to export');
            return;
        }

        // Build CSV - LSMP Report Format (17 columns)
        var headers = [
            'Alarm ID', 'Event Occur Time', 'Severity', 'Severity Name',
            'Trigger ID', 'Event Priority',
            'Item ID', 'Event ID',
            'Host ID', 'Host Name', 'IP Address', 'Host Groups',
            'Incident Number',
            'Event ID 2', 'Entity (Impacted CI)', 'Host', 'Message'
        ];

        var csv = headers.join(',') + '\n';

        problems.forEach(function(p) {
            var entity = p.snmp_component || p.host_name || '';
            var row = [
                p.problem_eventid, p.problem_start_time, p.problem_severity, p.problem_severity_name,
                p.trigger_triggerid, p.trigger_priority,
                p.item_itemid, p.item_name,
                p.host_hostid, p.host_name, p.interface_ip, p.host_groups,
                p.znuny_ticket_nr,
                p.snmp_item_event_id, entity, p.snmp_device, p.snmp_summary_message
            ].map(function(val) {
                if (val === null || val === undefined) return '';
                val = String(val).replace(/"/g, '""');
                if (val.indexOf(',') >= 0 || val.indexOf('"') >= 0 || val.indexOf('\n') >= 0) {
                    return '"' + val + '"';
                }
                return val;
            });
            csv += row.join(',') + '\n';
        });

        // Download
        var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        var link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = 'zabbix_problems_' + new Date().toISOString().slice(0,10) + '.csv';
        link.click();
    }

    // Apply entity filter to problems list (JS-side filtering)
    function applyEntityFilter(problems) {
        if (!entityFilter || !problems) return problems;
        return problems.filter(function(p) {
            var entity = p.snmp_component || p.host_name || '';
            return entity === entityFilter;
        });
    }

    // Show filter banners
    function showFilterBanners() {
        if (entityFilter) {
            var banner = document.getElementById('EntityFilterBanner');
            document.getElementById('EntityFilterName').textContent = entityFilter;
            banner.style.display = 'block';
        }
        if (hasTicketFilter === '1') {
            var banner = document.getElementById('HasTicketBanner');
            document.getElementById('HasTicketText').textContent = 'Showing: Events with linked Znuny ticket only';
            banner.style.display = 'block';
        } else if (hasTicketFilter === '0') {
            var banner = document.getElementById('HasTicketBanner');
            document.getElementById('HasTicketText').textContent = 'Showing: Events without linked Znuny ticket only';
            banner.style.display = 'block';
        }
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function() {
        showFilterBanners();

        if (initialSuccess) {
            totalCount = initialTotalCount;
            var filteredProblems = applyEntityFilter(initialProblems);
            renderProblems(filteredProblems);
            updatePaginationUI();
        } else if (initialError) {
            showError(initialError);
        }

        // Bind events
        document.getElementById('PrevPage').addEventListener('click', function() {
            if (currentPage > 0) {
                currentPage--;
                loadData();
            }
        });

        document.getElementById('NextPage').addEventListener('click', function() {
            var totalPages = Math.ceil(totalCount / pageSize) || 1;
            if (currentPage + 1 < totalPages) {
                currentPage++;
                loadData();
            }
        });

        document.getElementById('RefreshData').addEventListener('click', function() {
            currentPage = 0;
            loadData();
        });

        document.getElementById('DaysFilter').addEventListener('change', function() {
            currentPage = 0;
            loadData();
        });

        document.getElementById('LimitFilter').addEventListener('change', function() {
            currentPage = 0;
            loadData();
        });

        document.getElementById('ExportCSV').addEventListener('click', exportCSV);
    });

})();
</script>
